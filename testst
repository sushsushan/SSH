#!/bin/bash

# Apply terminal colors (for supported terminals)
if [[ "$TERM" == "xterm"* || "$TERM" == "gnome-terminal" || "$TERM" == "konsole" ]]; then
    echo -e "\033]11;#300A24\007"  # Background: Dark Purple
    echo -e "\033]10;#FFFFFF\007"  # Foreground: White
    echo -e "\033]12;#00FF00\007"  # Cursor: Green
    echo -e "\e[2 q"               # Block cursor
fi

clear

# Function to display available folders before cd
function change_directory() {
    echo "Available folders:"
    ls -d */ 2>/dev/null | awk '{print "📂 " $0}' # Show folders only

    read -p "Enter the directory to navigate into: " new_dir
    if [ -d "$new_dir" ]; then
        cd "$new_dir" || echo "Error: Failed to change directory!"
        echo "Changed directory to $(pwd)"
    else
        echo "Error: '$new_dir' is not a valid directory!"
    fi
}

# Function to create a backup
function create_backup() {
    echo "Current working directory: $(pwd)"
    
    read -p "Enter the path to the document directory: " document_dir
    if [ ! -d "$document_dir" ]; then
        echo "Error: '${document_dir}' is not a valid directory."
        exit 1
    fi
    
    clear
    echo "📂 Folders in ${document_dir}:"
    find "$document_dir" -maxdepth 1 -type d ! -path "$document_dir" | awk '{print "📁 " $0}'
    
    echo -e "\n📄 Files in ${document_dir}:"
    find "$document_dir" -maxdepth 1 -type f | awk '{print "📜 " $0}'
    
    read -p "Enter items to exclude (comma-separated, or leave blank): " exclude_items
    
    backup_dir="${HOME}/backup"
    mkdir -p "${backup_dir}"
    backup_filename="backup_$(date '+%Y%m%d_%H%M%S').tar.gz"
    backup_path="${backup_dir}/${backup_filename}"
    
    if [ -z "$exclude_items" ]; then
        tar -czhf "${backup_path}" "${document_dir}"
    else
        exclude_options=$(echo "$exclude_items" | sed 's/,/ --exclude=/g' | sed 's/^/--exclude=/')
        tar ${exclude_options} -czhf "${backup_path}" "${document_dir}"
    fi
    
    if [ -f "$backup_path" ]; then
        echo "✅ Backup successful: ${backup_path}"
    else
        echo "❌ Error creating backup!"
    fi
}

# Main menu loop
while true; do
    echo -e "\n🌟 Options:"
    echo "1️⃣ Change Directory"
    echo "2️⃣ Create Backup"
    echo "3️⃣ Exit"
    read -p "Select an option: " choice

    case $choice in
        1) change_directory ;;
        2) create_backup ;;
        3) echo "Exiting..."; exit 0 ;;
        *) echo "Invalid option! Try again." ;;
    esac
done
