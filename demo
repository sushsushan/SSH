#!/bin/bash

# Header of the table with fixed column width
printf "%-30s %-15s %-50s %-15s\n" "Domain" "Type" "Documentroot" "Userdirprotect"
echo "-----------------------------------------------------------------------------------------------"

# Command to get the data
output=$(uapi DomainInfo domains_data)

# Loop through the output and extract relevant fields for each domain
domain_list=$(echo "$output" | grep -i "domain" | awk '{print $2}')
type_list=$(echo "$output" | grep -i "type" | awk '{print $2}')
documentroot_list=$(echo "$output" | grep -i "documentroot" | awk '{print substr($0, index($0,$2))}')
userdirprotect_list=$(echo "$output" | grep -i "userdirprotect" | awk '{print $2}')

# Get the number of domains
count=$(echo "$domain_list" | wc -l)

# Loop through and print the data in structured table format
for i in $(seq 1 $count); do
  domain=$(echo "$domain_list" | sed -n "${i}p")
  type=$(echo "$type_list" | sed -n "${i}p")
  documentroot=$(echo "$documentroot_list" | sed -n "${i}p")
  userdirprotect=$(echo "$userdirprotect_list" | sed -n "${i}p")
  
  # Print each row in a properly formatted table
  printf "%-30s %-15s %-50s %-15s\n" "$domain" "$type" "$documentroot" "$userdirprotect"
done
