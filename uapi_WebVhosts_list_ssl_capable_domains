#!/bin/bash

# Fetch the data
data=$(uapi WebVhosts list_ssl_capable_domains)

# Initialize arrays
domains=()
vhosts=()
proxies=()

# Read values into arrays
while read -r line; do
    if [[ $line == " domain:"* ]]; then
        domains+=("$(echo "$line" | awk '{print $2}')")
    fi
    if [[ $line == " vhost_name:"* ]]; then
        vhosts+=("$(echo "$line" | awk '{print $2}')")
    fi
    if [[ $line == " is_proxy:"* ]]; then
        proxies+=("$(echo "$line" | awk '{print $2}')")
    fi
done <<< "$data"

# Find max column widths
max_domain=10
max_vhost=10

for d in "${domains[@]}"; do
    [[ ${#d} -gt $max_domain ]] && max_domain=${#d}
done

for v in "${vhosts[@]}"; do
    [[ ${#v} -gt $max_vhost ]] && max_vhost=${#v}
done

# Add padding
max_domain=$((max_domain + 5))
max_vhost=$((max_vhost + 5))

# Print header
printf "%-${max_domain}s | %-${max_vhost}s | %-7s\n" "Domain" "VHost Name" "Is Proxy"
printf "%-${max_domain}s | %-${max_vhost}s | %-7s\n" "$(printf -- '-%.0s' $(seq 1 $max_domain))" "$(printf -- '-%.0s' $(seq 1 $max_vhost))" "-------"

# Print records
for i in "${!domains[@]}"; do
    printf "%-${max_domain}s | %-${max_vhost}s | %-7s\n" "${domains[i]}" "${vhosts[i]}" "${proxies[i]}"
done
