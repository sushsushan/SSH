#!/bin/bash

clear
echo -e "\n🔍 Fetching available databases...\n"

DB_LIST=$(uapi Mysql list_databases | grep -oP '(?<=database:\s).+')

if [ -z "$DB_LIST" ]; then
    echo "❌ No databases found."
    exit 1
fi

echo -e "📌 Available Databases:\n$DB_LIST\n"

read -p "Enter database name: " DB_NAME

if ! echo "$DB_LIST" | grep -q "^$DB_NAME$"; then
    echo "❌ Error: Database '$DB_NAME' does not exist."
    exit 1
fi

DB_USER="$(whoami)_$(openssl rand -hex 4)"
DB_PASS=$(openssl rand -base64 12)

# Create temporary user
uapi Mysql create_user name="$DB_USER" password="$DB_PASS" >/dev/null 2>&1
uapi Mysql set_privileges_on_database database="$DB_NAME" user="$DB_USER" privileges="ALL PRIVILEGES" >/dev/null 2>&1

# Fetch database report
REPORT=$(mysql -u "$DB_USER" -p"$DB_PASS" -D "$DB_NAME" --silent --skip-column-names <<EOF 2>/dev/null

SELECT '─────────────────────────';
SELECT '🔥 DATABASE REPORT 🔥';
SELECT '─────────────────────────';

SELECT '📌 Database Summary';
SELECT '─────────────────────────';
SELECT DATABASE() AS 'Database', 
       COUNT(*) AS 'Total Tables', 
       ROUND(SUM(DATA_LENGTH + INDEX_LENGTH) / 1024 / 1024, 2) AS 'Total Size (MB)'
FROM information_schema.TABLES WHERE TABLE_SCHEMA = '$DB_NAME';

SELECT '─────────────────────────';
SELECT '📊 Largest Tables (Top 10)';
SELECT '─────────────────────────';
SELECT TABLE_NAME AS 'Table', 
       ROUND((DATA_LENGTH + INDEX_LENGTH) / 1024 / 1024, 2) AS 'Size (MB)' 
FROM information_schema.TABLES WHERE TABLE_SCHEMA = '$DB_NAME' 
ORDER BY (DATA_LENGTH + INDEX_LENGTH) DESC LIMIT 10;

SELECT '─────────────────────────';
SELECT '🛠️ Table Index & Fragmentation Report';
SELECT '─────────────────────────';
SELECT TABLE_NAME AS 'Table', 
       ENGINE, 
       ROUND(DATA_LENGTH / 1024 / 1024, 2) AS 'Data Size (MB)',
       ROUND(INDEX_LENGTH / 1024 / 1024, 2) AS 'Index Size (MB)',
       ROUND((DATA_FREE / 1024 / 1024), 2) AS 'Fragmented (MB)',
       TABLE_ROWS AS 'Rows'
FROM information_schema.TABLES WHERE TABLE_SCHEMA = '$DB_NAME'
ORDER BY DATA_FREE DESC LIMIT 10;

SELECT '─────────────────────────';
SELECT '🚨 Slow Queries & Performance';
SELECT '─────────────────────────';
SHOW GLOBAL STATUS LIKE 'Slow_queries';

SELECT '─────────────────────────';
SELECT '📊 Query Cache Status';
SELECT '─────────────────────────';
SHOW VARIABLES LIKE 'query_cache_%';

SELECT '─────────────────────────';
SELECT '⏳ Table Locking Statistics';
SELECT '─────────────────────────';
SHOW STATUS LIKE 'Table_locks%';

SELECT '─────────────────────────';
SELECT '🔎 Running Queries & Process List';
SELECT '─────────────────────────';
SHOW FULL PROCESSLIST;

SELECT '─────────────────────────';
SELECT '👤 Current User & Active Connections';
SELECT '─────────────────────────';
SELECT USER(), DATABASE();
EOF
)

# Remove temporary user
uapi Mysql delete_user name="$DB_USER" >/dev/null 2>&1

# Print report in clean format
echo -e "\n$REPORT\n✅ Report Generated Successfully!\n"
