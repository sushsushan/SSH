#!/bin/bash

# Run the command and store the output
output=$(uapi Variables get_user_information)

# Extract specific fields using grep and awk for formatting
echo "========================================"
echo " User Information Summary"
echo "========================================"

# Convert Unix timestamp to human-readable format
created_timestamp=$(echo "$output" | grep "created:" | awk '{print $2}')
created_human=$(date -d @"$created_timestamp" +"%Y-%m-%d %H:%M:%S")

last_modified_timestamp=$(echo "$output" | grep "last_modified:" | awk '{print $2}' | tr -d "'")
last_modified_human=$(date -d @"$last_modified_timestamp" +"%Y-%m-%d %H:%M:%S")

# Print the extracted values in a readable format
echo "Backup Enabled:       $(echo "$output" | grep "backup_enabled:" | awk '{print $2}')"
echo "Bandwidth Limit:      $(echo "$output" | grep "bandwidth_limit:" | awk '{print $2}')"
echo "CGI Enabled:          $(echo "$output" | grep "cgi_enabled:" | awk '{print $2}')"
echo "Contact Email:        $(echo "$output" | grep "contact_email:" | awk '{print $2}')"
echo "Created:              $created_human"
echo "Created in Version:   $(echo "$output" | grep "created_in_version:" | awk '{print $2}')"
echo "Dead Domains:         $(echo "$output" | grep -A5 "dead_domains:" | tail -n +2)"
echo "Disk Block Limit:     $(echo "$output" | grep "disk_block_limit:" | awk '{print $2}')"
echo "DKIM Enabled:         $(echo "$output" | grep "dkim_enabled:" | awk '{print $2}')"
echo "Domain:               $(echo "$output" | grep "domain:" | awk '{print $2}')"
echo "Domains:              $(echo "$output" | grep -A10 "domains:" | tail -n +2)"
echo "Feature List:         $(echo "$output" | grep "feature_list:" | awk '{print $2}')"
echo "Home Directory:       $(echo "$output" | grep "home:" | awk '{print $2}')"
echo "IP Address:           $(echo "$output" | grep "ip:" | awk '{print $2}')"
echo "Last Modified:        $last_modified_human"
echo "Locale:               $(echo "$output" | grep "locale:" | awk '{print $2}')"
echo "Mailbox Format:       $(echo "$output" | grep "mailbox_format:" | awk '{print $2}')"
echo "Max Docroot:          $(echo "$output" | grep "max_docroot:" | awk '{print $2}')"
echo "Max Domain:           $(echo "$output" | grep "max_domain:" | awk '{print $2}')"
echo "Max Addon Domains:    $(echo "$output" | grep "maximum_addon_domains:" | awk '{print $2}')"
echo "Max Databases:        $(echo "$output" | grep "maximum_databases:" | awk '{print $2}')"
echo "Max Email Quota:      $(echo "$output" | grep "maximum_email_account_disk_quota:" | awk '{print $2}')"
echo "Max Emails/Hour:      $(echo "$output" | grep "maximum_emails_per_hour:" | awk '{print $2}')"
echo "Max FTP Accounts:     $(echo "$output" | grep "maximum_ftp_accounts:" | awk '{print $2}')"
echo "Max Mail Accounts:    $(echo "$output" | grep "maximum_mail_accounts:" | awk '{print $2}')"
echo "Max Mailing Lists:    $(echo "$output" | grep "maximum_mailing_lists:" | awk '{print $2}')"
echo "Max Parked Domains:   $(echo "$output" | grep "maximum_parked_domains:" | awk '{print $2}')"
echo "Max Passenger Apps:   $(echo "$output" | grep "maximum_passenger_apps:" | awk '{print $2}')"
echo "Max Subdomains:       $(echo "$output" | grep "maximum_subdomains:" | awk '{print $2}')"
echo "MX Check:             $(echo "$output" | grep -A5 "mxcheck:" | tail -n +2)"
echo "Plan:                 $(echo "$output" | grep "plan:" | awk '{print $2}')"
echo "Shell:                $(echo "$output" | grep "shell:" | awk '{print $2}')"
echo "SPF Enabled:          $(echo "$output" | grep "spf_enabled:" | awk '{print $2}')"
echo "Theme:                $(echo "$output" | grep "theme:" | awk '{print $2}')"
echo "User:                 $(echo "$output" | grep "user:" | awk '{print $2}')"

echo "========================================"
echo " End of Report"
echo "========================================"
